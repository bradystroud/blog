{
  "name": "bradystroud",
  "version": "0.1.0",
  "packageManager": "bun@1.3.7",
  "scripts": {
    "postinstall": "bun scripts/patch-tinacms.js && (find node_modules -name '*.node' -exec xattr -d com.apple.quarantine {} + 2>/dev/null || true)",
    "dev": "bun run tinacms dev -c \"next dev\"",
    "build": "bun run --bun tinacms build && bun run --bun next build && bun run scripts/generate-rss.ts && bun run --bun next-sitemap --config next-sitemap.config.js",
    "generate-rss": "bun run scripts/generate-rss.ts",
    "start": "bun run --bun tinacms build && bun run --bun next start",
    "export": "bun run build && bun run --bun next export",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@svgr/webpack": "^8.1.0",
    "@tinacms/cli": "^2.5.1",
    "@types/node": "25.0.10",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "9.39.2",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.15",
    "postcss-nesting": "^14.0.0"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@headlessui/react": "2.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@vercel/analytics": "^1.6.1",
    "@vercel/og": "^0.8.6",
    "@vercel/speed-insights": "^1.3.1",
    "gray-matter": "^4.0.3",
    "next": "16.1.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.1",
    "tinacms": "^3.9.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "final-form": "4.20.1",
    "@types/node": "22.13.10"
  },
  "resolutions": {
    "@tinacms/graphql/date-fns": "2.30.0"
  }
}
